# ── Model selection ─────────────────────────────────────────────────────────────
# Recommended (good balance of speed and quality, ~4 GB download):
MODEL_ID=Qwen/Qwen2-VL-2B-Instruct

# Higher quality (needs 8 GB+ VRAM or 16 GB+ RAM, ~14 GB download):
# MODEL_ID=Qwen/Qwen2-VL-7B-Instruct

# Lightweight fallback (fastest on CPU, ~2 GB download):
# MODEL_ID=Qwen/Qwen2-VL-2B-Instruct

# ── Inference settings ───────────────────────────────────────────────────────────
# Device: "auto" lets accelerate choose GPU if available, CPU otherwise
DEVICE=auto
MAX_NEW_TOKENS=1024

# Enable 4-bit quantization (requires bitsandbytes: pip install bitsandbytes)
# Halves VRAM usage, slight quality drop
LOAD_IN_4BIT=false
